  mutate(date_start = make_datetime(year = year, 
                            month = month_start, 
                            day = day_start, 
                            hour = hour(hm(time_start)),
                            min = minute(hm(time_start))),
         date_end = make_datetime(year = year, 
                            month = month_end, 
                            day = day_end, 
                            hour = hour(hm(time_end)),
                            min = minute(hm(time_end))),
         diff = date_end - date_start, 
         wday = wday(date_start, label = TRUE))  |> 
  group_by(wday) |> 
  summarise(diff = sum(diff)) |>
  filter(diff == max(diff)) |> 
  pull(wday) |> 
  check_question(answer = _,
                 options = c("Пн", "Вт", "Ср", "Чт", "Пт", "Сб", "Вс"), 
                 type = "radio")
```

