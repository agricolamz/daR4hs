```{r}
#| include: false

task <- "В [датасете](https://raw.githubusercontent.com/agricolamz/daR4hs/main/data/2.2.{i}.csv) в формате `.csv` записан фрагмент данных аннотации 'Географии' Страбона, сделанной Элтоном Баркером для проекта Recogito. Скачайте датасет и определите в какой из книг Страбона аннотировано больше всего уникальных географических единиц."
```


####


```{r}
#| include: false

i <- 1
link <- str_glue("https://raw.githubusercontent.com/agricolamz/daR4hs/main/data/2.2.{i}.csv")
```


`r str_glue(task)`


```{r}
#| echo: false

read_csv(link) |> 
  distinct(FILE, QUOTE_TRANSCRIPTION) |> 
  count(FILE) |> 
  filter(n == max(n)) |> 
  pull(FILE)|> 
  nrow() |> 
  check_question(answer = _, options = str_c("Book ", 1:15), type = "radio")
```

