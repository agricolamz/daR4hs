### 2


```{r}
#| include: false

task <- "В [датасет](https://raw.githubusercontent.com/agricolamz/daR4hs/main/data/6.2.{i}.csv) записаны данные посещения некоторого сайта. Узнайте, в какие месяцы сумма посещений в 2021 и 2022 годах была строго больше, чем в 2023."  
```


####


```{r}
#| include: false

i <-  1
link <- str_glue("https://raw.githubusercontent.com/agricolamz/daR4hs/main/data/6.2.{i}.csv")
```


`r str_glue(task)`


```{r}
read_csv(link, show_col_types = FALSE) |> 
  mutate(date = dmy_hm(text),
         year = year(date),
         year = ifelse(year == 2023, "2023", "2021/2022"),
         month = month(date, label = TRUE)) |> 
  count(year, month) |> 
  pivot_wider(names_from = year, values_from = n) |> 
  filter(`2021/2022` > `2023`) |> 
  pull(month) |> 
  as.character() |> 
  str_replace("мая", "май") |> 
  check_question(answer = _,
                 options = c("янв", "фев", "мар", "апр", "май", "июн", "июл", "авг", "сен", "окт", "ноя", "дек"), 
                 type = "checkbox")  
```

```{r}
read_csv(link, show_col_types = FALSE) |> 
  mutate(date = dmy_hm(text),
         year = year(date),
         year = ifelse(year == 2023, "2023", "2021/2022"),
         month = month(date, label = TRUE)) |> 
  count(year, month) |> 
  pivot_wider(names_from = year, values_from = n, values_fill = 0) |> 
  filter(`2021/2022` > `2023`)
```


