  mutate(date = dmy_hm(text),
         year = year(date),
         year = ifelse(year == 2023, "2023", "2021/2022"),
         month = month(date, label = TRUE)) |> 
  count(year, month) |> 
  pivot_wider(names_from = year, values_from = n, values_fill = 0) |> 
  filter(`2021/2022` > `2023`)
```


